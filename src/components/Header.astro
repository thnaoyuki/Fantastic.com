---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2>
			<a href="/">{SITE_TITLE}</a>
		</h2>

		<details>
			<summary>☰</summary>

			<div class="menu-dropdown">
				<a href="/">Home</a>
				<a href="/blog">Archive</a>
				<a href="/about">About</a>
				<a href="/reading">Reading</a>
				<a href="/music">Music</a>
				<a href="/thought">Thought</a>
			</div>
		</details>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5rem;
		background: transparent;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 0;
	}

	h2 {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 400;
		letter-spacing: 0.08em;
	}

	h2 a {
		text-decoration: none;
		color: inherit;
	}

	details {
		position: relative;
	}

	summary {
		list-style: none;
		cursor: pointer;
		font-size: 1.6rem;
		user-select: none;
	}

	summary::-webkit-details-marker {
		display: none;
	}

	.menu-dropdown {
		position: absolute;
		right: 0;
		top: 120%;

		display: flex;
		flex-direction: column;

		min-width: 220px;
		padding: 1rem;

		background: rgba(255,255,255,0.95);
		border-radius: 12px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);

		z-index: 100;
	}

	.menu-dropdown a {
		text-decoration: none;
		color: inherit;
		padding: 0.6rem 0;
	}

	.menu-dropdown a:hover {
		opacity: 0.7;
	}

	@media (max-width: 720px) {
		.menu-dropdown {
			min-width: 180px;
		}
	}
</style>
